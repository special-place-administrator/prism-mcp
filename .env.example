# ╔══════════════════════════════════════════════════════════════════╗
# ║  Prism MCP — Environment Variables (.env.example)              ║
# ║  Copy this file to .env and fill in your keys.                 ║
# ║  Docs: https://github.com/ImpactMinded/prism-mcp              ║
# ╚══════════════════════════════════════════════════════════════════╝

# ─── Required: API Keys ────────────────────────────────────────────
# Brave Search Pro — powers web search and research tools
# Get yours at: https://brave.com/search/api/
BRAVE_API_KEY=

# Google AI Studio — powers Gemini LLM (synthesis, embeddings, images)
# Get yours at: https://aistudio.google.com/apikey
GOOGLE_API_KEY=

# ─── Optional: Brave Answers ───────────────────────────────────────
# Separate key for AI-grounded answers (brave_answers tool)
# BRAVE_ANSWERS_API_KEY=

# ─── Storage ───────────────────────────────────────────────────────
# "local" = SQLite (zero-config, good for dev)
# "supabase" = Supabase PostgreSQL (production, multi-device)
PRISM_STORAGE=local

# For Supabase storage, set these:
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_SERVICE_KEY=your-service-role-key

# ─── Dashboard ─────────────────────────────────────────────────────
PRISM_DASHBOARD_PORT=3333
# PRISM_DASHBOARD_AUTH=your-secret-password  # Optional: password-protect the dashboard

# ─── Background Scheduler (v5.4) ──────────────────────────────────
# Runs maintenance tasks: TTL sweep, importance decay, compaction, deep purge
PRISM_SCHEDULER_ENABLED=true
# PRISM_SCHEDULER_INTERVAL_MS=43200000  # Default: 12 hours

# ─── Autonomous Web Scholar (v5.4) ────────────────────────────────
# Background research pipeline: Brave Search → Firecrawl → Gemini → Ledger
# Requires: BRAVE_API_KEY + GOOGLE_API_KEY + FIRECRAWL_API_KEY
#
# Get your Firecrawl key at: https://www.firecrawl.dev/
FIRECRAWL_API_KEY=

# Enable the Scholar pipeline
PRISM_SCHOLAR_ENABLED=true

# Auto-run interval in ms (0 = manual only via dashboard button)
# 300000 = 5 min | 600000 = 10 min | 3600000 = 1 hour
PRISM_SCHOLAR_INTERVAL_MS=300000

# Comma-separated research topics
PRISM_SCHOLAR_TOPICS=ai,agents

# Max articles scraped per run (controls API costs)
PRISM_SCHOLAR_MAX_ARTICLES_PER_RUN=3

# ─── Telemetry (optional) ─────────────────────────────────────────
# OpenTelemetry endpoint for distributed tracing
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318/v1/traces

# ─── Debug ─────────────────────────────────────────────────────────
# Set to "true" for verbose logging (Scholar pipeline, embedding ops, etc.)
# DEBUG=true
